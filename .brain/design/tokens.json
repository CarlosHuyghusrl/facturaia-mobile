    "D": { "min": 40, "max": 54  },
    "E": { "min": 25, "max": 39  },
    "F": { "min": 0,  "max": 24  }
  },

  "css_variables_emit": {
    "_doc": "Para gestoriard: emitir CSS vars a partir de este JSON via script build-time",
    "selector": ":root[data-theme=\"perfilado-dark\"]",
    "output_file": "styles/perfilado-dark.css",
    "naming": "kebab-case con prefijo `--`: --grade-a, --bg, --text-primary, etc."
  }
